# pubignore — overrides .gitignore when present; mirror dev-only paths here.

# Dart / Flutter
.dart_tool/
.flutter-plugins-dependencies
**/doc/api/
build/
coverage/
pubspec.lock

# IDE / OS
.idea/
.vscode/
*.iml
.DS_Store

# Native build cache
.build/
.swiftpm/
/android/.gradle/
/android/build/

# Native binaries (downloaded by build)
/android/src/main/jniLibs/
/ios/mpv_audio_kit/Frameworks/libmpv.xcframework/
/ios/mpv_audio_kit/Frameworks/libmpv_xcframework.zip
/macos/mpv_audio_kit/Frameworks/libmpv.xcframework/
/macos/mpv_audio_kit/Frameworks/libmpv_xcframework.zip
/linux/libs/
/windows/libs/

# Docs
/docs/
/scripts/

# AI tooling
.claude/
CLAUDE.md
graphify-out/

# Tests
/test/
/test_app/

# Shared-source plumbing (maintainer-only). `darwin/Sources/` is the single
# source of truth for the Apple Swift the iOS/macOS plugins share; it is
# copied into each platform's Sources/ by scripts/sync_apple_sources.sh
# (scripts/ is already excluded above), so the published package needs only
# those real copies, not the shared tree.
/darwin/

# Codegen config
analysis_options.yaml

# Assets — whitelist only the screenshots referenced by pubspec.yaml
/imgs/*
!/imgs/mpv_audio_kit.png
